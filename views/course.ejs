<!DOCTYPE html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <meta name="description" content="<%= metaDescription %>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700&family=Outfit:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/styles.css" />
    <style>
      /* Per-course accent — injected here because values come from EJS data */
      :root {
        --course-accent:        <%= course.accentColor %>;
        --course-accent-dim:    <%= course.accentDim %>;
        --course-accent-border: <%= course.accentBorder %>;
      }
    </style>
  </head>
  <body>

    <%- include('partials/header') %>

    <main>

      <!-- ── Course Hero ── -->
      <section class="course-hero">
        <div class="container">
          <div class="audience-switcher">
            <a href="/#courses" class="back-link" style="margin-bottom:0">← Toate cursurile</a>
            <div class="audience-switcher-tabs">
              <a href="/cursuri/copii/<%= course.slug %>"
                 class="audience-tab<%= course.audience === 'copii' ? ' is-active' : '' %>">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
                Copii
              </a>
              <a href="/cursuri/adulti/<%= course.slug %>"
                 class="audience-tab<%= course.audience === 'adulti' ? ' is-active' : '' %>">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="0"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
                Adulți
              </a>
            </div>
          </div>
          <div class="course-hero-inner">
            <div>
              <span class="label course-accent" style="margin-bottom:1rem"><%= course.tagLabel %></span>
              <h1><%= course.title %></h1>
            </div>
            <div class="course-hero-right">
              <span class="course-hero-tag"><%= course.tagLabel %></span>
              <p><%= course.intro %></p>
              <div style="display:flex;gap:1rem;flex-wrap:wrap">
                <a href="/#contact" class="btn btn-primary">Înscrie-te acum</a>
                <a href="/#contact" class="btn btn-outline">Lecție gratuită</a>
              </div>
            </div>
          </div>

          <!-- Details strip -->
          <div class="details-strip">
            <% course.details.forEach(function(d) { %>
            <div class="detail-cell">
              <p class="detail-label"><%= d.label %></p>
              <p class="detail-value"><%= d.value %></p>
            </div>
            <% }); %>
            <%/* Phantom cells to complete the last row so border-top separators span full width */%>
            <% var _rem = course.details.length % 3; if (_rem > 0) { for (var _f = 0; _f < (3 - _rem); _f++) { %><div class="detail-cell detail-cell--phantom"></div><% }} %>
          </div>
        </div>
      </section>

      <!-- ── For Whom ── -->
      <section class="section">
        <div class="container">
          <div class="section-header">
            <div>
              <span class="label course-accent">Pentru cine</span>
              <h2>Grupele noastre.</h2>
            </div>
          </div>
          <div class="whom-grid">
            <% course.forWhom.forEach(function(w) { %>
            <div class="whom-cell">
              <p class="whom-group"><%= w.group %></p>
              <p class="whom-desc"><%= w.desc %></p>
            </div>
            <% }); %>
          </div>
        </div>
      </section>

      <!-- ── Curriculum ── -->
      <section class="section section--no-top">
        <div class="container">
          <div class="section-header">
            <div>
              <span class="label course-accent">Curriculum</span>
              <h2>Ce vom învăța.</h2>
            </div>
          </div>
          <div>
            <% course.curriculum.forEach(function(c) { %>
            <div class="curriculum-row">
              <span class="curriculum-num"><%= c.num %></span>
              <div>
                <p class="curriculum-title"><%= c.title %></p>
                <p class="curriculum-desc"><%= c.desc %></p>
              </div>
            </div>
            <% }); %>
          </div>
        </div>
      </section>

      <!-- ── Testimonials ──
      <section class="section section--no-top">
        <div class="container">
          <div class="section-header">
            <div>
              <span class="label label-orange">Testimoniale</span>
              <h2>Ce spun cursanții.</h2>
            </div>
          </div>
          <div class="course-testi-grid">
            <% course.testimonials.forEach(function(t) { %>
            <div class="course-testi-cell">
              <div class="testi-stars">★★★★★</div>
              <p class="testi-quote">"<%= t.quote %>"</p>
              <span class="testi-author"><%= t.author %></span>
            </div>
            <% }); %>
          </div>
        </div>
      </section> -->

      <!-- ── CTA ── -->
      <section>
        <div class="container">
          <div class="course-cta">
            <div>
              <span class="label course-accent">Începe acum</span>
              <h2>Rezervă locul tău<br>în grupă.</h2>
            </div>
            <div class="course-cta-actions">
              <a href="/#contact" class="btn btn-primary">Înscrie-te acum</a>
              <a href="/#contact" class="btn btn-outline">Lecție de probă gratuită</a>
            </div>
          </div>
        </div>
      </section>

    </main>

    <%- include('partials/footer') %>

    <div id="toast" class="toast" aria-live="polite"></div>
    <script src="/js/main.js"></script>
  </body>
</html>
