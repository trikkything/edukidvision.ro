<section id="contact" class="section section-tint">
  <div class="container contact-grid">
    <div class="contact-form-wrap card-soft">
      <div class="section-heading left-align">
        <span class="eyebrow">Contact</span>
        <h2>Tell us a little about your learner.</h2>
        <p>We will help you choose the right course and arrange a free trial lesson.</p>
      </div>

      <form id="contactForm" class="contact-form">
        <div class="form-row">
          <label>
            Name
            <input type="text" name="name" placeholder="Parent or student name" required />
          </label>
          <label>
            Email
            <input type="email" name="email" placeholder="you@example.com" required />
          </label>
        </div>
        <div class="form-row">
          <label>
            Phone
            <input type="tel" name="phone" placeholder="07xx xxx xxx" required />
          </label>
          <label>
            Child's age
            <input type="text" name="age" placeholder="Age or adult learner" required />
          </label>
        </div>
        <label>
          Course interest
          <select name="course" required>
            <option value="">Select a course</option>
            <option>English Lessons</option>
            <option>Leadership Courses</option>
            <option>IT Courses</option>
          </select>
        </label>
        <label>
          Message
          <textarea name="message" rows="5" placeholder="Tell us about your goals, schedule, or questions" required></textarea>
        </label>
        <button type="submit" class="btn btn-primary btn-full">Send Inquiry</button>
      </form>
    </div>

    <div class="contact-details">
      <div class="details-card card-soft">
        <h3>Visit or contact us</h3>
        <ul class="details-list">
          <li><strong>Address:</strong> 12 Learning Lane, Bucharest</li>
          <li><strong>Phone:</strong> +40 721 000 000</li>
          <li><strong>Email:</strong> hello@edukidvision.ro</li>
          <li><strong>Hours:</strong> Mon-Fri 10:00-19:00, Sat 10:00-14:00</li>
        </ul>
      </div>
      <div class="map-card card-soft">
        <h3>Location</h3>
        <div class="map-placeholder">Map placeholder</div>
      </div>
      <div class="cta-banner">
        <h3>Ready to start? Book a free trial lesson.</h3>
        <a href="#contact" class="btn btn-primary">Book a Free Trial</a>
      </div>
    </div>
  </div>
</section>
