<section id="courses" class="section">
  <div class="container">

    <div class="section-header">
      <div>
        <span class="label label-green">Cursuri</span>
        <h2>Programe pentru<br>fiecare pas.</h2>
      </div>
    </div>

    <div class="toggle" role="tablist" aria-label="Selectare public cursuri">
      <button class="toggle-btn is-active" data-audience="kids" aria-selected="true">Pentru copii</button>
      <button class="toggle-btn" data-audience="adults" aria-selected="false">Pentru adulți</button>
    </div>

    <div>

      <a href="/cursuri/engleza" class="course-row" data-course-card>
        <span class="course-num">01</span>
        <div class="course-body">
          <div class="course-name">Cursuri de Engleză</div>
          <p class="course-desc course-description"
             data-kids="Vocabular, fluență, conversație și pregătire pentru examene prin sesiuni dinamice adaptate vârstei."
             data-adults="Comunicare la locul de muncă, gramatică solidă și engleză practică pentru carieră sau călătorii.">
            Vocabular, fluență, conversație și pregătire pentru examene prin sesiuni dinamice adaptate vârstei.
          </p>
          <div class="course-meta" data-kids-age="Vârste 6–17 ani" data-adults-age="18+ ani">
            <span class="course-tag course-tag-en">
              <strong class="course-age">Vârste 6–17 ani</strong>
            </span>
          </div>
        </div>
        <span class="course-arrow" aria-hidden="true">→</span>
      </a>

      <a href="/cursuri/leadership" class="course-row" data-course-card>
        <span class="course-num">02</span>
        <div class="course-body">
          <div class="course-name">Cursuri de Leadership</div>
          <p class="course-desc course-description"
             data-kids="Vorbire în public, lucru în echipă și rezolvarea de probleme prin proiecte și activități ghidate."
             data-adults="Abilități de prezentare, coordonare și comunicare pentru viața profesională și personală.">
            Vorbire în public, lucru în echipă și rezolvarea de probleme prin proiecte și activități ghidate.
          </p>
          <div class="course-meta" data-kids-age="Vârste 8–17 ani" data-adults-age="18+ ani">
            <span class="course-tag course-tag-lead">
              <strong class="course-age">Vârste 8–17 ani</strong>
            </span>
          </div>
        </div>
        <span class="course-arrow" aria-hidden="true">→</span>
      </a>

      <a href="/cursuri/it" class="course-row" data-course-card>
        <span class="course-num">03</span>
        <div class="course-body">
          <div class="course-name">Cursuri de IT</div>
          <p class="course-desc course-description"
             data-kids="Bazele programării, robotică și educație digitală prin lecții practice care fac tehnologia accesibilă și creativă."
