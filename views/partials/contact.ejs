<section id="contact" class="section">
  <div class="container">

    <div class="section-header">
      <div>
        <span class="label label-teal">Contact</span>
        <h2>Programează o<br>lecție gratuită.</h2>
      </div>
    </div>

    <div class="contact-grid">
      <div class="contact-form-wrap">
        <p style="margin-bottom:1.75rem">Spune-ne câte ceva despre cursant și te ajutăm să alegi cursul potrivit.</p>

        <!-- Thank-you panel — hidden until form submits successfully -->
        <div id="contactThanks" class="contact-thanks" style="display:none">
          <div class="contact-thanks-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <h3 class="contact-thanks-title">Mulțumim!</h3>
          <p class="contact-thanks-text">Mesajul tău a fost trimis cu succes. Echipa noastră îl va analiza și te vom contacta în cel mai scurt timp posibil pentru a stabili detaliile lecției gratuite.</p>
          <p class="contact-thanks-sub">Ne auzim curând! 👋</p>
        </div>

        <form id="contactForm" class="contact-form">
          <div class="form-row">
            <label>
              Nume
              <input type="text" name="name" placeholder="Numele părintelui sau al cursantului" required />
            </label>
            <label>
              Email
              <input type="email" name="email" placeholder="you@example.com" required />
            </label>
          </div>
          <div class="form-row">
            <label>
              Telefon
              <input type="tel" name="phone" placeholder="07xx xxx xxx" required />
            </label>
            <label>
              Vârsta
              <input type="text" name="age" placeholder="Vârsta copilului sau adult" required />
            </label>
          </div>
          <label>
            Interes pentru curs
            <select name="course" required>
              <option value="">Selectează un curs</option>
              <% (activeCourses || []).forEach(function(course) { %>
                <option value="<%= course.title %>"><%= course.title %></option>
              <% }); %>
            </select>
          </label>
          <label>
            Mesaj
            <textarea name="message" rows="4" placeholder="Obiective, program sau întrebări" required></textarea>
          </label>
          <button type="submit" class="btn btn-primary btn-full">Trimite solicitarea</button>
        </form>
      </div>

      <div class="contact-details">
        <div>
          <p class="details-label">Vizitează-ne</p>
          <ul class="details-list">
            <li><strong>Adresă</strong> Str. Vârful cu dor, nr. 18, Arad</li>
            <li><strong>Telefon</strong> +40 745 547 177</li>
            <li><strong>Email</strong> contact@edukidvision.ro</li>
            <li><strong>Program</strong> Luni–Vineri 12:00–19:00<br>Sâmbătă, Duminică - închis</li>
          </ul>
        </div>
        <div>
          <p class="details-label">Locație</p>
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2762.9809982456572!2d21.305064076825303!3d46.17103397109435!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x60fdf0c152248249%3A0x2584794c049fa6ab!2sEdukid%20Vision!5e0!3m2!1sen!2sro!4v1781515291772!5m2!1sen!2sro" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
            width="300"
            height="225"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
        <!-- <div class="cta-inline">
          <h3>Ești gata să începi?</h3>
          <a href="#contact" class="btn btn-primary">Programează o lecție gratuită</a>
        </div> -->
      </div>
    </div>

  </div>
</section>
