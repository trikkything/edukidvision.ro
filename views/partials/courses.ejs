<%
  /* Use activeCourses injected by res.locals middleware */
  const _ac = typeof activeCourses !== 'undefined' ? activeCourses : [];
  const _kids   = _ac.filter(c => c.audience === 'copii');
  const _adults = _ac.filter(c => c.audience === 'adulti');

  /* Short description: first non-empty line of intro, capped at 140 chars */
  function shortDesc(intro) {
    if (!intro) return '';
    const first = intro.split('\n').find(l => l.trim().length > 0) || '';
    return first.length > 140 ? first.substring(0, 137) + '…' : first;
  }
%>

<% if (_ac.length > 0) { %>
<section id="courses" class="section">
  <div class="container">

    <div class="section-header">
      <div>
        <span class="label label-green">Cursuri</span>
        <h2>Programe pentru<br>fiecare pas.</h2>
      </div>
    </div>

    <!-- ── Banda copii ── -->
    <% if (_kids.length > 0) { %>
    <div class="courses-band">
      <div class="courses-band-header courses-band-header--kids">
        <svg class="courses-band-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
          <path d="M6 12v5c3 3 9 3 12 0v-5"/>
        </svg>
        <span class="courses-band-label">Pentru copii</span>
        <span class="courses-band-age">Vârste 6–17 ani</span>
      </div>
      <% _kids.forEach(function(c, i) { %>
      <a href="/cursuri/copii/<%= c.slug %>" class="course-row">
        <span class="course-num"><%= String(i + 1).padStart(2, '0') %></span>
        <div class="course-body">
          <div class="course-name"><%= c.title %></div>
          <p class="course-desc"><%= shortDesc(c.intro) %></p>
          <div>
            <span class="course-tag" style="color:<%= c.accentColor %>;border-color:<%= c.accentBorder %>">
              <%= c.tagLabel %>
            </span>
          </div>
        </div>
        <span class="course-arrow" aria-hidden="true">→</span>
      </a>
      <% }); %>
    </div>
    <% } %>

    <!-- ── Banda adulți ── -->
    <% if (_adults.length > 0) { %>
    <div class="courses-band">
      <div class="courses-band-header courses-band-header--adults">
        <svg class="courses-band-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="7" width="20" height="14" rx="0"/>
          <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
          <line x1="12" y1="12" x2="12" y2="16"/>
          <line x1="10" y1="14" x2="14" y2="14"/>
        </svg>
        <span class="courses-band-label">Pentru adulți</span>
        <span class="courses-band-age">18+ ani</span>
      </div>
      <% _adults.forEach(function(c, i) { %>
      <a href="/cursuri/adulti/<%= c.slug %>" class="course-row">
        <span class="course-num"><%= String(i + 1).padStart(2, '0') %></span>
        <div class="course-body">
          <div class="course-name"><%= c.title %></div>
          <p class="course-desc"><%= shortDesc(c.intro) %></p>
          <div>
            <span class="course-tag" style="color:<%= c.accentColor %>;border-color:<%= c.accentBorder %>">
              <%= c.tagLabel %>
            </span>
          </div>
        </div>
        <span class="course-arrow" aria-hidden="true">→</span>
      </a>
      <% }); %>
    </div>
    <% } %>

  </div>
</section>
<% } %>
