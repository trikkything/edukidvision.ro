<% if (typeof latestPosts !== 'undefined' && latestPosts.length > 0) { %>
<%
  const _featured    = latestPosts.filter(p => p.featured);
  const _nonFeatured = latestPosts.filter(p => !p.featured);
%>
<section class="section-news-preview" id="noutati">
  <div class="container">

    <div class="section-header" style="margin-bottom:0">
      <div>
        <span class="label label-teal">Noutăți</span>
        <h2>Ultimele noutăți.</h2>
      </div>
    </div>

    <!-- Featured cards — full-width horizontal -->
    <% if (_featured.length > 0) { %>
    <div class="news-featured-list">
      <% _featured.forEach(function(p) { %>
      <article class="news-card--featured">
        <% if (p.coverImage) { %>
        <a href="/noutati/<%= p.slug %>" class="news-featured-image-wrap">
          <img src="<%= p.coverImage %>" alt="<%= p.title %>" class="news-featured-image" loading="lazy" />
        </a>
        <% } else { %>
        <div class="news-featured-image-wrap news-featured-image-wrap--empty"></div>
        <% } %>
        <div class="news-featured-body">
          <div class="news-card-meta">
            <span class="news-card-featured">★ Promovat</span>
            <span class="news-card-category"><%= p.category %></span>
            <span class="news-card-date"><%= new Date(p.publishDate).toLocaleDateString('ro-RO', { day:'numeric', month:'long', year:'numeric' }) %></span>
          </div>
          <h3 class="news-featured-title">
            <a href="/noutati/<%= p.slug %>"><%= p.title %></a>
          </h3>
          <p class="news-featured-excerpt"><%= p.excerpt %></p>
          <a href="/noutati/<%= p.slug %>" class="btn btn-outline btn--sm">Citește articolul →</a>
        </div>
      </article>
      <% }); %>
    </div>
    <% } %>

    <!-- Regular cards grid -->
    <% if (_nonFeatured.length > 0) { %>
    <div class="news-grid<%= _featured.length > 0 ? ' news-grid--below-featured' : '' %>">
      <% _nonFeatured.forEach(function(p) { %>
      <article class="news-card">
        <% if (p.coverImage) { %>
        <a href="/noutati/<%= p.slug %>" class="news-card-image-wrap">
          <img src="<%= p.coverImage %>" alt="<%= p.title %>" class="news-card-image" loading="lazy" />
        </a>
        <% } %>
        <div class="news-card-body">
          <div class="news-card-meta">
            <span class="news-card-category"><%= p.category %></span>
            <span class="news-card-date"><%= new Date(p.publishDate).toLocaleDateString('ro-RO', { day:'numeric', month:'long', year:'numeric' }) %></span>
          </div>
          <h3 class="news-card-title">
            <a href="/noutati/<%= p.slug %>"><%= p.title %></a>
          </h3>
          <p class="news-card-excerpt"><%= p.excerpt %></p>
          <a href="/noutati/<%= p.slug %>" class="news-card-cta">Citește mai mult →</a>
        </div>
      </article>
      <% }); %>
    </div>
    <% } %>

    <div class="news-preview-footer">
      <a href="/noutati" class="btn btn-outline">Toate noutățile</a>
    </div>

  </div>
</section>
<% } %>
