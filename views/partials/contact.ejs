<section id="contact" class="section">
  <div class="container">

    <div class="section-header">
      <div>
        <span class="label label-teal">Contact</span>
        <h2>Programează o<br>lecție gratuită.</h2>
      </div>
    </div>

    <div class="contact-grid">
      <div class="contact-form-wrap">
        <p style="margin-bottom:1.75rem">Spune-ne câte ceva despre cursant și te ajutăm să alegi cursul potrivit.</p>

        <form id="contactForm" class="contact-form">
          <div class="form-row">
            <label>
              Nume
              <input type="text" name="name" placeholder="Numele părintelui sau al cursantului" required />
            </label>
            <label>
              Email
              <input type="email" name="email" placeholder="you@example.com" required />
            </label>
          </div>
          <div class="form-row">
            <label>
              Telefon
              <input type="tel" name="phone" placeholder="07xx xxx xxx" required />
            </label>
            <label>
              Vârsta
              <input type="text" name="age" placeholder="Vârsta copilului sau adult" required />
            </label>
          </div>
          <label>
            Interes pentru curs
            <select name="course" required>
              <option value="">Selectează un curs</option>
              <option>Cursuri de Engleză</option>
              <option>Cursuri de Leadership</option>
              <option>Cursuri de IT</option>
            </select>
          </label>
          <label>
            Mesaj
            <textarea name="message" rows="4" placeholder="Obiective, program sau întrebări" required></textarea>
          </label>
          <button type="submit" class="btn btn-primary btn-full">Trimite solicitarea</button>
        </form>
      </div>

      <div class="contact-details">
        <div>
          <p class="details-label">Vizitează-ne</p>
          <ul class="details-list">
            <li><strong>Adresă</strong> 12 Learning Lane, București</li>
            <li><strong>Telefon</strong> +40 721 000 000</li>
            <li><strong>Email</strong> hello@edukidvision.ro</li>
            <li><strong>Program</strong> Luni–Vineri 10:00–19:00 · Sâmbătă 10:00–14:00</li>
          </ul>
        </div>
        <div>
          <p class="details-label">Locație</p>
          <div class="map-placeholder">Hartă aici</div>
        </div>
        <div class="cta-inline">
          <h3>Ești gata să începi?</h3>
          <a href="#contact" class="btn btn-primary">Programează o lecție gratuită</a>
        </div>
      </div>
    </div>

  </div>
</section>
