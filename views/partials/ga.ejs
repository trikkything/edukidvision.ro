<!-- Google Consent Mode v2 — defaults BEFORE gtag loads -->
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}

  // Default: everything denied until user consents
  gtag('consent', 'default', {
    analytics_storage:   'denied',
    ad_storage:          'denied',
    ad_user_data:        'denied',
    ad_personalization:  'denied',
    wait_for_update:     500
  });

  // If user already consented in a previous visit, restore immediately
  (function() {
    try {
      var c = localStorage.getItem('ekv_consent');
      if (c === 'granted') {
        gtag('consent', 'update', {
          analytics_storage:  'granted',
          ad_storage:         'granted',
          ad_user_data:       'granted',
          ad_personalization: 'granted'
        });
      }
    } catch(e) {}
  })();
</script>

